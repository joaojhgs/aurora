{
  "name": "@aurora/tauri-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit --incremental false && vite build",
    "build:bundle": "pnpm prepare:sidecar && pnpm tauri build --config src-tauri/tauri.conf.json",
    "android:init": "tauri android init --ci --skip-targets-install && node ./scripts/install-android-native-plugin.mjs",
    "android:build:apk": "tauri android build --apk",
    "android:build:apk:x86_64": "tauri android build --apk --target x86_64",
    "android:build:apk:x86_64:debug": "tauri android build --debug --apk --target x86_64",
    "android:build:apk:split": "tauri android build --apk --split-per-abi",
    "android:build:aab": "tauri android build --aab",
    "android:smoke": "node ./scripts/android-emulator-smoke.mjs",
    "android:release-gate": "node ./scripts/android-release-gate.mjs",
    "android:release-gate:strict": "node ./scripts/android-release-gate.mjs --strict",
    "ios:policy": "node ./scripts/ios-release-gate.mjs --policy-only",
    "ios:gate": "node ./scripts/ios-release-gate.mjs --require-macos --require-ios-project",
    "ios:gate:signing": "node ./scripts/ios-release-gate.mjs --require-macos --require-ios-project --require-signing-env",
    "ios:build:app-store": "pnpm ios:gate:signing && pnpm tauri ios build --export-method app-store-connect && node ./scripts/ios-release-gate.mjs --require-macos --require-ios-project --require-signing-env --validate-ipa",
    "ios:open-xcode": "pnpm tauri ios build --open",
    "prepare:sidecar": "node ./scripts/prepare-sidecar.mjs",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "vitest run --environment jsdom",
    "tauri": "tauri"
  },
  "dependencies": {
    "@aurora/client": "workspace:*",
    "@aurora/ui": "workspace:*",
    "@tauri-apps/api": "^2.9.0",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.5",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.1",
    "jsdom": "^27.3.0",
    "typescript": "5.7.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.16"
  }
}
