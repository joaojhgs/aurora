{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aurora",
  "version": "0.1.0",
  "identifier": "dev.aurora.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aurora",
        "label": "main",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "capabilities": ["aurora-main"],
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:*; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
