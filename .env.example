# Aurora — copy to `.env` and customize (`.env` is gitignored).
# Docker Compose and Tilt load `.env` from the repo root automatically.

# =============================================================================
# Secrets & local dev (thread mode / apps)
# =============================================================================

AURORA_DEBUG_LOGS=false

OPENAI_API_KEY=
HUGGINGFACE_ACCESS_TOKEN=
JIRA_API_TOKEN=
BRAVE_API_KEY=
GITHUB_APP_PRIVATE_KEY=
SLACK_USER_TOKEN=
GOOGLE_CREDENTIALS_FILE=google_credentials.json

AURORA_TOKEN_SECRET=
AURORA_WEBRTC_PASSWORD=
AURORA_GATEWAY_API_KEYS=

# =============================================================================
# Architecture (containers often override via compose environment)
# =============================================================================

AURORA_ARCHITECTURE_MODE=threads
REDIS_URL=redis://localhost:6379

# =============================================================================
# Process mode / Docker Compose / Tilt
# =============================================================================

# Host "audio" group GID for stt-coordinator /dev/snd (optional; default 29 in compose).
# `scripts/sync-stt-audio-gid-in-dotenv.sh` updates this in `.env` when it changes.
STT_HOST_AUDIO_GID=29

# Published gateway port (docker-compose.process.yml)
GATEWAY_HOST_PORT=8000

# Tilt watchmedo debounce (docker-compose.tilt.yml)
AURORA_HOT_RELOAD_DEBOUNCE_SEC=0.5

# Config file inside containers (process/Tilt compose default: repo bind-mount).
# If /app/host/config.json is a directory (wrong compose context), ConfigService falls back to /app/config.json.
# AURORA_CONFIG_FILE=/app/host/config.json

# Optional: force wake word ONNX path (otherwise services.stt.wakeword.model_path in config.json).
# AURORA_WAKE_WORD_MODEL_PATH=/app/host/voice_models/jarvis.onnx

# Per-service AURORA_LOG_LEVEL via compose (docker-compose.tilt.yml). Tilt UI buttons
# and scripts/tilt-set-service-log-level.sh edit these in `.env`.
CONFIG_SERVICE_LOG_LEVEL=INFO
DB_SERVICE_LOG_LEVEL=INFO
AUTH_SERVICE_LOG_LEVEL=INFO
ORCHESTRATOR_SERVICE_LOG_LEVEL=INFO
GATEWAY_SERVICE_LOG_LEVEL=INFO
TTS_SERVICE_LOG_LEVEL=INFO
STT_TRANSCRIPTION_SERVICE_LOG_LEVEL=INFO
STT_WAKEWORD_SERVICE_LOG_LEVEL=INFO
SCHEDULER_SERVICE_LOG_LEVEL=INFO
TOOLING_SERVICE_LOG_LEVEL=INFO
STT_COORDINATOR_SERVICE_LOG_LEVEL=INFO

# Optional ngrok local_resource in Tiltfile
# NGROK_GATEWAY_PORT=8000

# Optional: PulseAudio instead of raw ALSA for coordinator (advanced)
# PULSE_SERVER=unix:/run/user/1000/pulse/native
