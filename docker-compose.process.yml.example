# Example configuration file for Aurora Process Mode
# Copy this to docker-compose.process.yml and customize as needed

version: '3.8'

services:
  # Redis for BullMQBus (process mode communication)
  redis:
    image: redis:7-alpine
    container_name: aurora-redis
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
    command: redis-server --appendonly yes
    networks:
      - aurora-network
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped
    # Uncomment to set memory limits
    # deploy:
    #   resources:
    #     limits:
    #       memory: 512M

  # Config Service (must start first)
  config-service:
    build:
      context: .
      dockerfile: Dockerfile.process
    container_name: aurora-config
    command: python -m app.services.config
    environment:
      - AURORA_ENV=production
      - AURORA_ARCHITECTURE_MODE=processes
      - REDIS_URL=redis://redis:6379
      - AURORA_LOG_LEVEL=INFO
      - PYTHONUNBUFFERED=1
    volumes:
      - ./data:/app/data
      - ./config:/app/config
      - ./logs:/app/logs
      - ./config.json:/app/config.json:ro
    networks:
      - aurora-network
    depends_on:
      redis:
        condition: service_healthy
    restart: unless-stopped
    # Uncomment to set resource limits
    # deploy:
    #   resources:
    #     limits:
    #       memory: 256M
    #       cpus: '0.5'

networks:
  aurora-network:
    driver: bridge

volumes:
  redis_data:
    driver: local

# Add other services following the same pattern
# See docker-compose.process.yml for the full configuration
