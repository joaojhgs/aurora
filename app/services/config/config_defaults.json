{
    "general": {
        "llm": {
            "provider": "openai",
            "third_party": {
                "openai": {
                    "options": {
                        "model": "gpt-4o",
                        "temperature": 0.7,
                        "max_tokens": 512
                    }
                },
                "huggingface_endpoint": {
                    "options": {
                        "endpoint_url": "",
                        "model": "",
                        "access_token": "",
                        "temperature": 0.7,
                        "max_tokens": 512
                    }
                }
            },
            "local": {
                "huggingface_pipeline": {
                    "options": {
                        "model": "microsoft/DialoGPT-medium",
                        "temperature": 0.7,
                        "torch_dtype": "auto"
                    }
                },
                "llama_cpp": {
                    "options": {
                        "model_path": "",
                        "temperature": 1.0,
                        "max_tokens": 512,
                        "n_ctx": 2048,
                        "n_gpu_layers": 0,
                        "n_batch": 1000,
                        "top_p": 0.95,
                        "top_k": 64,
                        "repeat_penalty": 1.0,
                        "min_p": 0.0,
                        "chat_format": "chatml-function-calling"
                    }
                }
            }
        },
        "embeddings": {
            "use_local": true
        },
        "speech_to_text": {
            "language": "en",
            "ambient_transcription": {
                "enable": false,
                "chunk_duration": 3.0,
                "storage_path": "ambient_logs/",
                "filter_short_transcriptions": true,
                "min_transcription_length": 10
            },
            "audio_input": {
                "device_index": null,
                "sample_rate": 16000,
                "channels": 1,
                "chunk_size": 1024,
                "format": "int16"
            },
            "wake_word": {
                "enabled": true,
                "backend": "oww",
                "model_path": null,
                "threshold": 0.5,
                "inference_framework": "onnx"
            },
            "transcription": {
                "vad_enabled": true,
                "vad_threshold": 0.5,
                "silence_duration_ms": 900,
                "max_speech_duration_s": 30,
                "realtime_model": {
                    "enabled": true,
                    "model_size": "tiny",
                    "device": "cpu",
                    "compute_type": "int8"
                },
                "accurate_model": {
                    "enabled": true,
                    "model_size": "base",
                    "device": "cpu",
                    "compute_type": "int8"
                }
            },
            "coordinator": {
                "session_timeout_s": 10.0,
                "multi_turn_enabled": false,
                "pause_tts_on_listen": true
            }
        },
        "text_to_speech": {
            "model_file_path": "voice_models/en_US-lessac-medium.onnx",
            "model_config_file_path": "voice_models/en_US-lessac-medium.onnx.txt",
            "model_sample_rate": 22050,
            "piper_path": ""
        },
        "hardware_acceleration": {
            "tts": false,
            "stt": false,
            "ocr_bg": false,
            "ocr_curr": false,
            "llm": false
        }
    },
    "ui": {
        "activate": false,
        "dark_mode": false,
        "debug": false
    },
    "plugins": {
        "google": {
            "credentials_file": "google_credentials.json"
        },
        "jira": {
            "activate": false,
            "api_token": "",
            "username": "",
            "instance_url": "https://jira.atlassian.net/"
        },
        "openrecall": {
            "activate": false
        },
        "brave_search": {
            "activate": false,
            "api_key": ""
        },
        "github": {
            "activate": false,
            "app_id": "",
            "app_private_key": "",
            "repository": ""
        },
        "slack": {
            "activate": false,
            "user_token": ""
        },
        "gmail": {
            "activate": false
        },
        "gcalendar": {
            "activate": false
        }
    },
    "mcp": {
        "enabled": true,
        "servers": {}
    },
    "gateway": {
        "enabled": false,
        "host": "0.0.0.0",
        "port": 8000,
        "request_timeout_s": 30.0,
        "cors": {
            "origins": ["*"],
            "allow_credentials": true
        },
        "auth": {
            "enabled": false,
            "api_keys": [],
            "token_expiry_days": 365,
            "session_token_expiry_hours": 24,
            "pairing_code_expiry_minutes": 5,
            "pairing_max_attempts_per_ip": 5,
            "default_pairing_permissions": [],
            "webrtc_auth_timeout_seconds": 10.0,
            "webrtc_pairing_timeout_seconds": 300.0,
            "audit_enabled": true,
            "audit_retention_days": 90
        },
        "mesh": {
            "enabled": false,
            "node_name": "",
            "services": {
                "TTS": { "share": false, "max_concurrent": 10, "prefer": "local", "fallback": "local" },
                "STTCoordinator": { "share": false, "max_concurrent": 10, "prefer": "local", "fallback": "local" },
                "WakeWord": { "share": false, "max_concurrent": 10, "prefer": "local", "fallback": "local" },
                "Transcription": { "share": false, "max_concurrent": 10, "prefer": "local", "fallback": "local" },
                "DB": { "share": false, "max_concurrent": 10, "prefer": "local", "fallback": "local" },
                "Orchestrator": { "share": false, "max_concurrent": 10, "prefer": "local", "fallback": "local" },
                "Tooling": { "share": false, "max_concurrent": 10, "prefer": "local", "fallback": "local" },
                "Scheduler": { "share": false, "max_concurrent": 10, "prefer": "local", "fallback": "local" },
                "Config": { "share": false, "max_concurrent": 10, "prefer": "local", "fallback": "local" }
            },
            "version_policy": "compatible",
            "peer_selection": "lowest_latency",
            "ping_interval_s": 30.0,
            "registry_announce_interval_s": 60.0,
            "stale_peer_timeout_s": 120.0,
            "remote_timeout_s": 30.0
        },
        "webrtc": {
            "enabled": false,
            "strategy": "mqtt",
            "app_id": "aurora",
            "room": "default",
            "password": "",
            "encrypt_signaling": true,
            "enable_app_layer_e2ee": false,
            "stun_servers": [
                "stun:stun.l.google.com:19302"
            ],
            "turn_servers": []
        },
        "signaling_mqtt": {
            "brokers": [
                "wss://broker.emqx.io:8084/mqtt",
                "wss://test.mosquitto.org:8081/mqtt"
            ],
            "topic_root": "aurora"
        }
    }
}