# Additional ignores for process mode Docker builds
# This extends .dockerignore

# Process mode specific
*.process.yml
docker-compose*.yml
README.process-mode.md

# Development files
*.md
!readme.md
docs/
tests/
scripts/docker-process-mode.sh

# Git
.git/
.gitignore

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.*
!.env.example
