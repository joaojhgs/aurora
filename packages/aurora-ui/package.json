{
  "name": "@aurora/ui",
  "version": "0.1.0",
  "description": "Production React shell, design tokens, and SDK-bound UI primitives for Aurora.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./dist/styles.css",
    "./src/styles.css"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp src/styles.css dist/styles.css",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "vitest run --environment node"
  },
  "dependencies": {
    "@aurora/client": "workspace:*",
    "lucide-react": "^1.16.0",
    "react": "^19"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react-dom": "^19",
    "typescript": "5.7.3",
    "vitest": "^4.0.16"
  }
}
