# Aurora Environment Variables
# Copy to .env and fill in values. Secrets and keys only; other settings use config.json.
# Config overrides .env at runtime for hot-reload.

# --- Logging ---
AURORA_DEBUG_LOGS=false

# --- LLM ---
OPENAI_API_KEY=

# --- Plugins: HuggingFace ---
HUGGINGFACE_ACCESS_TOKEN=

# --- Plugins: Jira ---
JIRA_API_TOKEN=

# --- Plugins: Brave Search ---
BRAVE_API_KEY=

# --- Plugins: GitHub ---
GITHUB_APP_PRIVATE_KEY=

# --- Plugins: Slack ---
SLACK_USER_TOKEN=

# --- Plugins: Google ---
GOOGLE_CREDENTIALS_FILE=google_credentials.json

# --- Gateway ---
AURORA_TOKEN_SECRET=
AURORA_WEBRTC_PASSWORD=
AURORA_GATEWAY_API_KEYS=

# --- Architecture ---
AURORA_ARCHITECTURE_MODE=threads
REDIS_URL=redis://localhost:6379
