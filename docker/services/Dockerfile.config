# Config Service Dockerfile
FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV AURORA_ENV=production
ENV AURORA_ARCHITECTURE_MODE=processes
ENV REDIS_URL=redis://redis:6379

RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd -r aurora && useradd -r -g aurora -s /bin/bash aurora
WORKDIR /app

# Install UV
RUN pip install uv

# Copy project files first for better caching
COPY --chown=aurora:aurora pyproject.toml ./
# Process mode: only ConfigService reads this file; must exist in build context (repo root).
COPY --chown=aurora:aurora config.json ./config.json
COPY --chown=aurora:aurora app/ app/
COPY --chown=aurora:aurora modules/ modules/

# Install dependencies using pyproject.toml optional groups
# Config service only needs core + service-config + mode-processes
RUN uv pip install --system --no-cache -e .[service-config,mode-processes]

RUN mkdir -p /app/data /app/logs /app/cache /app/config && \
    chown -R aurora:aurora /app

USER aurora

CMD ["python", "-m", "app.services.config"]

