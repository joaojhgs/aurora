# syntax=docker/dockerfile:1.7
# Orchestrator Service Dockerfile
# Supports multiple LLM provider modes via build arg ORCHESTRATOR_LLM_MODE:
#   - "openai" (default): Uses OpenAI API, smaller image (~200MB)
#   - "huggingface-endpoint": Uses HuggingFace endpoint API, small image (~250MB)
#   - "huggingface-local": Uses local HuggingFace pipeline, larger image (~7GB)
#   - "llama-cpp": Uses llama.cpp CPU, medium image (~700MB)
#   - "llama-cpp-cuda": Uses llama.cpp CUDA, medium image (~700MB)
# Usage:
#   docker build --build-arg ORCHESTRATOR_LLM_MODE=openai -f docker/services/Dockerfile.orchestrator -t aurora-orchestrator:openai .
#   docker build --build-arg ORCHESTRATOR_LLM_MODE=huggingface-local -f docker/services/Dockerfile.orchestrator -t aurora-orchestrator:hf-local .
FROM python:3.11-slim

ARG ORCHESTRATOR_LLM_MODE=openai
ARG ORCHESTRATOR_HARDWARE=cpu

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV AURORA_ENV=production
ENV AURORA_ARCHITECTURE_MODE=processes
ENV REDIS_URL=redis://redis:6379
ENV UV_LINK_MODE=copy

RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    && rm -rf /var/lib/apt/lists/*

ARG AURORA_UID=1000
ARG AURORA_GID=1000
RUN groupadd -g ${AURORA_GID} aurora && useradd -u ${AURORA_UID} -g aurora -m -s /bin/bash aurora
WORKDIR /app

# Install UV
RUN pip install uv

# Copy only dependency manifests first so source edits do not invalidate package layers.
COPY --chown=aurora:aurora pyproject.toml uv.lock ./

# Base orchestrator always includes service-orchestrator + mode-processes.
# Then add optional LLM provider dependencies based on ORCHESTRATOR_LLM_MODE.
RUN --mount=type=cache,target=/root/.cache/uv \
    case "$ORCHESTRATOR_LLM_MODE" in \
        "openai") \
            echo "Installing orchestrator dependencies with OpenAI (smaller - ~200MB)"; \
            uv export --frozen --no-dev --no-emit-project --format requirements.txt \
              --extra service-orchestrator --extra mode-processes \
              > /tmp/requirements.txt; \
            ;; \
        "huggingface-endpoint") \
            echo "Installing orchestrator dependencies with HuggingFace endpoint (small - ~250MB)"; \
            uv export --frozen --no-dev --no-emit-project --format requirements.txt \
              --extra service-orchestrator --extra service-orchestrator-huggingface-endpoint \
              --extra mode-processes > /tmp/requirements.txt; \
            ;; \
        "huggingface-local") \
            echo "Installing orchestrator dependencies with HuggingFace local pipeline (larger - ~7GB)"; \
            uv export --frozen --no-dev --no-emit-project --format requirements.txt \
              --extra service-orchestrator --extra service-orchestrator-huggingface-local \
              --extra mode-processes > /tmp/requirements.txt; \
            ;; \
        "llama-cpp"*) \
            echo "Installing orchestrator dependencies with llama.cpp (hardware: $ORCHESTRATOR_HARDWARE)"; \
            uv export --frozen --no-dev --no-emit-project --format requirements.txt \
              --extra service-orchestrator --extra mode-processes \
              > /tmp/requirements.txt; \
            uv pip install --system -r /tmp/requirements.txt; \
            # Install llama-cpp-python based on hardware
            case "$ORCHESTRATOR_HARDWARE" in \
                cuda) \
                    uv pip install --system llama-cpp-python --extra-index-url=https://abetlen.github.io/llama-cpp-python/whl/cu124/ || \
                    uv pip install --system llama-cpp-python[cuda]; \
                    ;; \
                rocm) \
                    uv pip install --system llama-cpp-python --extra-index-url=https://abetlen.github.io/llama-cpp-python/whl/rocm/ || \
                    CMAKE_ARGS="-DGGML_HIPBLAS=ON" uv pip install --system llama-cpp-python; \
                    ;; \
                metal) \
                    uv pip install --system llama-cpp-python --extra-index-url=https://abetlen.github.io/llama-cpp-python/whl/metal/ || \
                    CMAKE_ARGS="-DGGML_METAL=ON" uv pip install --system llama-cpp-python; \
                    ;; \
                vulkan) \
                    CMAKE_ARGS="-DGGML_VULKAN=ON" uv pip install --system llama-cpp-python; \
                    ;; \
                sycl) \
                    CMAKE_ARGS="-DGGML_SYCL=ON -DCMAKE_C_COMPILER=icx -DCMAKE_CXX_COMPILER=icpx" uv pip install --system llama-cpp-python; \
                    ;; \
                rpc) \
                    CMAKE_ARGS="-DGGML_RPC=ON" uv pip install --system llama-cpp-python; \
                    ;; \
                *) \
                    uv pip install --system llama-cpp-python --extra-index-url=https://abetlen.github.io/llama-cpp-python/whl/cpu/ || \
                    CMAKE_ARGS="-DGGML_BLAS=ON -DGGML_BLAS_VENDOR=OpenBLAS" uv pip install --system llama-cpp-python; \
                    ;; \
            esac; \
            rm -f /tmp/requirements.txt; \
            ;; \
        *) \
            echo "Unknown ORCHESTRATOR_LLM_MODE: $ORCHESTRATOR_LLM_MODE, defaulting to openai"; \
            uv export --frozen --no-dev --no-emit-project --format requirements.txt \
              --extra service-orchestrator --extra mode-processes \
              > /tmp/requirements.txt; \
            ;; \
    esac && \
    if [ -f /tmp/requirements.txt ]; then uv pip install --system -r /tmp/requirements.txt; fi

COPY --chown=aurora:aurora app/ app/
COPY --chown=aurora:aurora modules/ modules/
RUN uv pip install --system --no-deps -e .

RUN mkdir -p /app/data /app/logs /app/cache /app/config && \
    chown -R aurora:aurora /app

USER aurora

CMD ["python", "-m", "app.services.orchestrator"]
